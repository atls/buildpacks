{
  "imagePrefix": "ghcr.io/atls",
  "registry": "ghcr.io",
  "stackId": "tech.atls.stacks.node",
  "packVersion": "0.40.4",
  "platforms": ["linux/amd64", "linux/arm64"],
  "nodeLines": ".github/docker-release-node-lines.json",
  "workflowOnlyPaths": [".github/workflows/docker-release.yaml"],
  "stackBaseDockerfile": "stacks/node/base/Dockerfile",
  "builderConfig": "builders/base/builder.toml",
  "stacks": [
    {
      "tag": "base",
      "context": "stacks/node/base"
    },
    {
      "tag": "build",
      "context": "stacks/node/build"
    },
    {
      "tag": "run",
      "context": "stacks/node/run"
    }
  ],
  "extensions": [
    {
      "name": "curl",
      "directory": "extensions/curl",
      "imageRepository": "ghcr.io/atls/buildpack-extension-curl"
    },
    {
      "name": "htop",
      "directory": "extensions/htop",
      "imageRepository": "ghcr.io/atls/buildpack-extension-htop"
    },
    {
      "name": "graphql-hive",
      "directory": "extensions/graphql-hive",
      "imageRepository": "ghcr.io/atls/buildpack-extension-graphql-hive"
    }
  ],
  "buildpacks": [
    {
      "name": "require-extension",
      "directory": "buildpacks/require-extension",
      "imageRepository": "ghcr.io/atls/buildpack-require-extension"
    },
    {
      "name": "yarn-install",
      "directory": "buildpacks/yarn-install",
      "imageRepository": "ghcr.io/atls/buildpack-yarn-install"
    },
    {
      "name": "yarn-cache",
      "directory": "buildpacks/yarn-cache",
      "imageRepository": "ghcr.io/atls/buildpack-yarn-cache"
    },
    {
      "name": "yarn-workspace-start",
      "directory": "buildpacks/yarn-workspace-start",
      "imageRepository": "ghcr.io/atls/buildpack-yarn-workspace-start"
    }
  ],
  "buildpackGroup": {
    "name": "yarn-workspace",
    "directory": "buildpacks/yarn-workspace",
    "imageRepository": "ghcr.io/atls/buildpack-yarn-workspace"
  },
  "scanImageKinds": ["builder-base", "stack-node-base", "stack-node-build", "stack-node-run"]
}
