{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "bootstrap-sha": "98386bca9834ab0bfc627549f949f794817fad62",
  "include-v-in-tag": false,
  "skip-changelog": true,
  "label": "release: pending",
  "release-label": "release: tagged",
  "changelog-sections": [
    {
      "type": "feat",
      "section": "Features"
    },
    {
      "type": "fix",
      "section": "Bug Fixes"
    },
    {
      "type": "deps",
      "section": "Dependencies"
    },
    {
      "type": "build",
      "section": "Build System"
    },
    {
      "type": "chore",
      "section": "Maintenance"
    }
  ],
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "cnb-buildpack-family",
      "components": [
        "buildpack-root",
        "buildpack-require-extension",
        "buildpack-yarn-cache",
        "buildpack-yarn-install",
        "buildpack-yarn-workspace",
        "buildpack-yarn-workspace-start",
        "libcnb"
      ]
    },
    {
      "type": "linked-versions",
      "groupName": "cnb-extension-family",
      "components": [
        "buildpack-extension-curl",
        "buildpack-extension-graphql-hive",
        "buildpack-extension-htop"
      ]
    }
  ],
  "packages": {
    ".": {
      "component": "buildpack-root",
      "exclude-paths": [
        ".github",
        "builders",
        "buildpacks",
        "extensions",
        "libcnb",
        "scripts",
        "stacks"
      ],
      "include-component-in-tag": true,
      "release-type": "node"
    },
    "buildpacks/require-extension": {
      "component": "buildpack-require-extension",
      "include-component-in-tag": true,
      "release-type": "simple",
      "extra-files": [
        {
          "type": "toml",
          "path": "buildpack.toml",
          "jsonpath": "$.buildpack.version"
        }
      ]
    },
    "buildpacks/yarn-cache": {
      "component": "buildpack-yarn-cache",
      "include-component-in-tag": true,
      "release-type": "simple",
      "extra-files": [
        {
          "type": "toml",
          "path": "buildpack.toml",
          "jsonpath": "$.buildpack.version"
        }
      ]
    },
    "buildpacks/yarn-install": {
      "component": "buildpack-yarn-install",
      "include-component-in-tag": true,
      "release-type": "simple",
      "extra-files": [
        {
          "type": "toml",
          "path": "buildpack.toml",
          "jsonpath": "$.buildpack.version"
        }
      ]
    },
    "buildpacks/yarn-workspace": {
      "component": "buildpack-yarn-workspace",
      "include-component-in-tag": true,
      "release-type": "simple",
      "extra-files": [
        {
          "type": "toml",
          "path": "buildpack.toml",
          "jsonpath": "$.buildpack.version"
        },
        {
          "type": "generic",
          "path": "buildpack.toml"
        },
        {
          "type": "generic",
          "path": "package.toml"
        }
      ]
    },
    "buildpacks/yarn-workspace-start": {
      "component": "buildpack-yarn-workspace-start",
      "include-component-in-tag": true,
      "release-type": "simple",
      "extra-files": [
        {
          "type": "toml",
          "path": "buildpack.toml",
          "jsonpath": "$.buildpack.version"
        }
      ]
    },
    "extensions/curl": {
      "component": "buildpack-extension-curl",
      "include-component-in-tag": true,
      "release-type": "simple",
      "extra-files": [
        {
          "type": "toml",
          "path": "extension.toml",
          "jsonpath": "$.extension.version"
        },
        {
          "type": "generic",
          "path": "/builders/base/builder.toml"
        },
        {
          "type": "generic",
          "path": "/builders/base/builder.release.toml"
        }
      ]
    },
    "extensions/graphql-hive": {
      "component": "buildpack-extension-graphql-hive",
      "include-component-in-tag": true,
      "release-type": "simple",
      "extra-files": [
        {
          "type": "toml",
          "path": "extension.toml",
          "jsonpath": "$.extension.version"
        },
        {
          "type": "generic",
          "path": "/builders/base/builder.toml"
        },
        {
          "type": "generic",
          "path": "/builders/base/builder.release.toml"
        }
      ]
    },
    "extensions/htop": {
      "component": "buildpack-extension-htop",
      "include-component-in-tag": true,
      "release-type": "simple",
      "extra-files": [
        {
          "type": "toml",
          "path": "extension.toml",
          "jsonpath": "$.extension.version"
        },
        {
          "type": "generic",
          "path": "/builders/base/builder.toml"
        },
        {
          "type": "generic",
          "path": "/builders/base/builder.release.toml"
        }
      ]
    },
    "libcnb": {
      "component": "libcnb",
      "include-component-in-tag": true,
      "release-type": "node"
    }
  }
}
